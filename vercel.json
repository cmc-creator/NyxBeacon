{
  "buildCommand": "npm run build",
  "outputDirectory": "packages/client/dist",
  "installCommand": "npm install --force",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": [
    "DATABASE_URL"
  ]
}
